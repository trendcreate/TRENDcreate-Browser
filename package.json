{
  "name": "trendcreate_browser",
  "version": "1.1.4",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:win:portable": "electron-builder --win portable",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "https://github.com/castlabs/electron-releases.git#v42.0.0+wvcus",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "dompurify": "^3.4.6",
    "monaco-editor": "^0.55.1",
    "pdfjs-dist": "^5.7.284"
  },
  "build": {
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/v"
    },
    "appId": "com.trendcreate.browser.v2",
    "productName": "TRENDcreate Browser",
    "directories": {
      "output": "dist"
    },
    "fileAssociations": [
      {
        "ext": "html",
        "name": "HTML Document",
        "role": "Viewer"
      },
      {
        "ext": "pdf",
        "name": "PDF Document",
        "role": "Viewer"
      }
    ],
    "files": [
      "main.js",
      "manifest.json",
      "package.json",
      "src/**/*",
      "node_modules/monaco-editor/**/*",
      "node_modules/dompurify/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
